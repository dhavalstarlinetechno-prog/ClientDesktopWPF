<UserControl x:Class="ClientDesktop.View.Navigation.BanScript"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ClientDesktop.View.Navigation"
             mc:Ignorable="d" 
             Height="240" Width="320">
    <Border BorderBrush="Gray"
            BorderThickness="1"
            Padding="6">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Orientation="Horizontal"
                     Margin="0,0,0,8">
                <!--<Image x:Name="Banscriptimage"
                    Width="24"
                    Height="24"
                    Stretch="Uniform"/>-->

                <Viewbox Width="24" Height="24">
                    <Canvas Width="100" Height="100">
                        <Path Fill="#00ADEF" Stroke="#002B5B" StrokeThickness="3"
                                Data="M20 15C20 12.2386 22.2386 10 25 10H60L80 30V85C80 87.7614 77.7614 90 75 90H25C22.2386 90 20 87.7614 20 85V15Z" />

                        <Path Fill="#00F2FF" Stroke="#002B5B" StrokeThickness="2"
                                Data="M60 10V25C60 27.7614 62.2386 30 65 30H80L60 10Z" />

                        <Path Stroke="#002B5B" StrokeThickness="4" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                Data="M35 50H65 M35 60H55 M35 70H45" />

                        <Path Fill="#FFD700" Stroke="#002B5B" StrokeThickness="2"
                                Data="M70,48 A22,22 0 1,1 70,92 A22,22 0 1,1 70,48 Z" />

                        <Path Stroke="#002B5B" StrokeThickness="5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                Data="M62 62L78 78 M78 62L62 78" />
                    </Canvas>
                </Viewbox>

                <TextBlock Text="Ban Script"
                        FontSize="15"
                        FontWeight="Bold"
                        VerticalAlignment="Center"
                        Margin="8,0,0,0"/>
            </StackPanel>

            <!-- Date -->
            <WrapPanel Grid.Row="1"
                    Margin="0,0,0,6">
                <TextBlock Text="Today's Banscripts Data"
                        FontSize="12"/>

                <TextBlock x:Name="LblBanscripiptdate"
                        FontSize="12"
                        Margin="5,0,0,0"/>
            </WrapPanel>

            <!-- Grid -->
            <Grid Grid.Row="2">
                <DataGrid x:Name="DgvBanScript"
                       ItemsSource="{Binding GridRows}"
                       Style="{StaticResource CustomDataGrid}"   
                       AutoGenerateColumns="False"
                       IsReadOnly="True"
                       CanUserSortColumns="False"
                       SelectionMode="Single"
                       HeadersVisibility="Column"
                       GridLinesVisibility="All"
                       BorderThickness="0"
                       SelectionUnit="FullRow"
                       CanUserAddRows="False"
                       CanUserDeleteRows="False"                      
                       VerticalScrollBarVisibility="Auto">

                    <DataGrid.Columns>
                        <DataGridTextColumn
                            Header="Symbol" FontFamily="Microsoft Sans Serif"
                            Binding="{Binding Symbol}"
                            Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <!--<Setter Property="VerticalAlignment" Value="Center"/>-->
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>

                    <!--<DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="Transparent"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>-->

                    <!-- ✅ FIX: Cell selection color hatane ke liye -->
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="Black"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="CornflowerBlue"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="FontWeight" Value="Regular"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                </DataGrid>

                <!-- No Data -->
                <TextBlock x:Name="LblNoData"
                        Text="No Data Available"
                        FontSize="15"                                   
                        Foreground="Gray"  
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top" 
                        FontFamily="Microsoft Sans Serif" Margin="0,34,0,0"
                        Visibility="Collapsed">

                    <!--<TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>

                                --><!-- Show only after data loaded AND no rows --><!--
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsDataLoaded}" Value="True"/>
                                        <Condition Binding="{Binding GridRows.Count}" Value="0"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>

                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>-->
                </TextBlock>

            </Grid>
        </Grid>

    </Border>
</UserControl>
