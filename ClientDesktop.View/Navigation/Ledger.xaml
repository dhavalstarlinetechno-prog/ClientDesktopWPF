<UserControl x:Class="ClientDesktop.View.Navigation.Ledger"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ClientDesktop.View.Navigation"
             mc:Ignorable="d" 
             Height="600" Width="1000" Loaded="UserControl_Loaded">

    <!-- ================= BUTTON STYLE (NO HOVER CHANGE) ================= -->
    <UserControl.Resources>
        <Style x:Key="FixedBlueButtonStyle" TargetType="Button">
            <!-- Default (Enabled State) -->
            <Setter Property="Background" Value="CornflowerBlue"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderBrush" Value="CornflowerBlue"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>

            <!-- Custom Template -->
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3">
                            <ContentPresenter 
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            RecognizesAccessKey="True"
                            TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <!-- When Disabled -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="Black"/>
                                <Setter TargetName="border" Property="Opacity" Value="0.7"/>
                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>

        </Style>
    </UserControl.Resources>
    
    

    <Grid>
        <!-- ================= PASSWORD / INFO PANEL ================= -->
        <Border x:Name="Mainpanel"
         BorderBrush="Gray"
         BorderThickness="1"
         Visibility="Visible">

            <Grid>
                <Grid VerticalAlignment="Top" Margin="15,30,15,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Viewbox Width="35" Height="35" Margin="0,2,10,0" VerticalAlignment="Top" Grid.Column="0">
                        <Canvas Width="24" Height="24">
                            <Path Fill="#F3B021" Data="M19,3H5C3.9,3,3,3.9,3,5v14c0,1.1,0.9,2,2,2h14c1.1,0,2-0.9,2-2V5C21,3.9,20.1,3,19,3z"/>
                            <Path Fill="#FFFFFF" Data="M7,7h10v4H7V7z M7,13h2v2H7V13z M11,13h2v2h-2V13z M15,13h2v2h-2V13z M7,17h2v2H7V17z M11,17h2v2h-2V17z M15,17h2v2h-2V17z"/>
                        </Canvas>
                    </Viewbox>

                    <TextBlock x:Name="Lbldetails"
                   Grid.Column="1"
                   FontWeight="Bold"
                   TextWrapping="Wrap"
                   FontSize="15.5"                  
                   LineHeight="22"
                   Text="This report represents sample ledger format. It contains sample data only for education purpose. Ledger can be displayed in below structure." 
                   FontFamily="Microsoft Sans Serif"
                   VerticalAlignment="Top"/>
                </Grid>

                <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

                    <PasswordBox x:Name="TxtPassword"
                     Width="227"
                     Height="27"
                     VerticalContentAlignment="Center"
                     PasswordChanged="TxtPassword_PasswordChanged" 
                     FontFamily="Microsoft Sans Serif" 
                     FontSize="13"/>

                    <Button x:Name="Btngo"
                Content="Go"
                Width="82"
                Height="30"                      
                Margin="10,0" 
                FontFamily="Microsoft Sans Serif"        
                Click="Btngo_Click"                      
                Style="{StaticResource FixedBlueButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ================= LEDGER / CHILD PANEL ================= -->
        <Border x:Name="ChildPanel"
         BorderBrush="Gray"
         BorderThickness="1"
         Visibility="Collapsed">

            <Grid>

                <!-- Top Controls -->
                <Grid Height="45" VerticalAlignment="Top">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <!-- Start Date Label -->
                    <TextBlock Text="Start Date:"
                               FontWeight="Bold"
                               FontSize="13"
                               Margin="10,0"
                               VerticalAlignment="Center"
                               FontFamily="Microsoft Sans Serif"/>

                    <!-- Start Date Picker -->
                    <DatePicker x:Name="Dtpstartdate"
                                Style="{StaticResource CustomDatePickerStyle}"
                                Grid.Column="1"
                                Width="135"
                                Height="26"
                                VerticalAlignment="Center"/>

                    <!-- End Date Label -->
                    <TextBlock Grid.Column="2"
                               Text="End Date:"
                               FontWeight="Bold"
                               FontSize="13"
                               Margin="10,0"
                               VerticalAlignment="Center"
                               FontFamily="Microsoft Sans Serif"/>

                    <!-- End Date Picker -->
                    <DatePicker x:Name="Dtpenddate"
                                Style="{StaticResource CustomDatePickerStyle}"
                                Grid.Column="3"
                                Width="135"
                                Height="26"
                                VerticalAlignment="Center"/>

                    <Button x:Name="Btngetdata"
                     Grid.Column="4"
                     Content="Go"
                     Width="82"
                     Height="30"                                 
                     Margin="10,0" 
                     Click="Btngetdata_Click" 
                     FontFamily="Microsoft Sans Serif"           
                     Style="{StaticResource FixedBlueButtonStyle}"/>

                    <StackPanel Grid.Column="6"
                         Orientation="Horizontal"
                         HorizontalAlignment="Right"
                         Margin="0,0,10,0">

                        <TextBlock Text="Amount:"
                            FontWeight="Bold"
                            VerticalAlignment="Center"
                            FontFamily="Microsoft Sans Serif"   
                            FontSize="13"          
                            Margin="0,0,5,0"/>

                        <TextBlock x:Name="Lblprintamount"
                            Text=""
                            VerticalAlignment="Center"
                            Visibility="Collapsed"
                            FontFamily="Microsoft Sans Serif"   
                            FontSize="13"       
                            Margin="0,0,15,0"/>

                        <Button x:Name="ExcelExportBtn" ToolTip="Export to Excel" Width="40" Height="40" Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="5,0" Visibility="Collapsed" Click="ExcelExportBtn_Click">
                            <Viewbox Width="30" Height="30">
                                <Grid>
                                    <Path Fill="#217346" Data="M4,4 H20 A2,2 0 0 1 22,6 V26 A2,2 0 0 1 20,28 H4 A2,2 0 0 1 2,26 V6 A2,2 0 0 1 4,4 Z" />
                                    <Path Fill="#107C41" Opacity="0.5" Data="M22,15 V26 A2,2 0 0 1 20,28 H12 L22,15 Z" />
                                    <Path Stroke="White" StrokeThickness="0.8" Opacity="0.3" Data="M12,8 H18 M12,12 H18 M12,16 H18 M12,20 H18 M12,24 H18 M11,8 V24" />
                                    <Border Background="#185C37" CornerRadius="2" Margin="0,4,10,4" HorizontalAlignment="Left" Width="12" Height="12">
                                        <Grid>
                                            <Path Fill="White" Opacity="0.1" Data="M0,0 H14 L0,14 Z" />
                                            <TextBlock Text="X" Foreground="White" FontSize="9" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="Segoe UI" />
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Viewbox>
                        </Button>
                        <Button x:Name="PdfExportBtn" ToolTip="Export to PDF" Width="40" Height="40" Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="5,0" Click="PdfExportBtn_Click" Visibility="Collapsed">
                            <Viewbox Width="30" Height="30">
                                <Grid>
                                    <Path Fill="#B30B00" Data="M4,4 H20 A2,2 0 0 1 22,6 V26 A2,2 0 0 1 20,28 H4 A2,2 0 0 1 2,26 V6 A2,2 0 0 1 4,4 Z" />
                                    <Path Fill="#7A0800" Opacity="0.4" Data="M22,15 V26 A2,2 0 0 1 20,28 H12 L22,15 Z" />
                                    <Path Stroke="White" StrokeThickness="1" Opacity="0.3" Data="M6,10 H16 M6,14 H18 M6,18 H18 M6,22 H12" />
                                    <Border Background="#E52521" CornerRadius="1" Margin="8,10,0,4" VerticalAlignment="Bottom" HorizontalAlignment="Right" Padding="1,0">
                                        <TextBlock Text="PDF" Foreground="White" FontSize="6" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="Segoe UI" />
                                    </Border>
                                </Grid>
                            </Viewbox>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- DataGrid -->
                <DataGrid x:Name="DgvLedgerRecord"
                   Style="{StaticResource CustomDataGrid}"       
                   Margin="3,62,3,3"
                   AutoGenerateColumns="True"
                   IsReadOnly="True"
                   SelectionMode="Single"
                   CanUserSortColumns="False"      
                   HeadersVisibility="Column"
                   GridLinesVisibility="All"
                   SelectionUnit="FullRow"
                   CanUserAddRows="False"
                   CanUserDeleteRows="False"
                   VerticalScrollBarVisibility="Auto"                  
                   BorderThickness="0"/>

               <TextBlock x:Name="TxtNoData"
               Text="No Data Available"
               FontSize="24"             
               Foreground="Gray"
               Visibility="Collapsed"
               HorizontalAlignment="Center"
               VerticalAlignment="Center" Margin="0,0,0,250" FontFamily="Microsoft Sans Serif"/>
            </Grid>
        </Border>
    </Grid>
    
</UserControl>
