<UserControl x:Class="ClientDesktop.View.Navigation.Ledger"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ClientDesktop.View.Navigation"
             mc:Ignorable="d" 
             d:DesignHeight="1000" d:DesignWidth="653" Loaded="UserControl_Loaded">

    <!-- ================= BUTTON STYLE (NO HOVER CHANGE) ================= -->
    <UserControl.Resources>
        <Style x:Key="FixedBlueButtonStyle" TargetType="Button">
            <!-- Default (Enabled State) -->
            <Setter Property="Background" Value="CornflowerBlue"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderBrush" Value="CornflowerBlue"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>

            <!-- Custom Template -->
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3">
                            <ContentPresenter 
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            RecognizesAccessKey="True"
                            TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <!-- When Disabled -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="Black"/>
                                <Setter TargetName="border" Property="Opacity" Value="0.7"/>
                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>

        </Style>
    </UserControl.Resources>
    
    

    <Grid>
        <!-- ================= PASSWORD / INFO PANEL ================= -->
        <Border x:Name="Mainpanel"
         BorderBrush="Gray"
         BorderThickness="1"
         Visibility="Visible">

            <Grid>

                <!-- Password Section -->
                <StackPanel Orientation="Horizontal"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center">

                    <PasswordBox x:Name="TxtPassword"
                          Width="227"
                          Height="27"
                          VerticalContentAlignment="Center"
                          PasswordChanged="TxtPassword_PasswordChanged" 
                          HorizontalAlignment="Center" 
                          VerticalAlignment="Center" 
                          FontFamily="Microsoft Sans Serif" 
                          FontSize="13"/>

                    <Button x:Name="Btngo"
                     Content="Go"
                     Width="82"
                     Height="30"                     
                     Margin="10,0" 
                     FontFamily="Microsoft Sans Serif"       
                     Click="Btngo_Click"                     
                     Style="{StaticResource FixedBlueButtonStyle}"/>
                </StackPanel>

                <!-- Details -->
                <TextBlock x:Name="Lbldetails"
                    Margin="65,30,65,0"
                    FontWeight="Bold"
                    TextWrapping="Wrap"
                    VerticalAlignment="Top"
                    FontSize="15"
                    Text="This report represents sample ledger format. It contains sample data only for education purpose. Ledger can be displayed in below structure." FontFamily="Microsoft Sans Serif"/>
                <Image HorizontalAlignment="Left" Height="40" Margin="9,29,0,0" VerticalAlignment="Top" Width="50"/>
            </Grid>
        </Border>

        <!-- ================= LEDGER / CHILD PANEL ================= -->
        <Border x:Name="ChildPanel"
         BorderBrush="Gray"
         BorderThickness="1"
         Visibility="Collapsed">

            <Grid>

                <!-- Top Controls -->
                <Grid Height="45" VerticalAlignment="Top">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <!-- Start Date Label -->
                    <TextBlock Text="Start Date:"
                               FontWeight="Bold"
                               FontSize="13"
                               Margin="10,0"
                               VerticalAlignment="Center"
                               FontFamily="Microsoft Sans Serif"/>

                    <!-- Start Date Picker -->
                    <DatePicker x:Name="Dtpstartdate"
                                Grid.Column="1"
                                Width="135"
                                Height="26"
                                VerticalAlignment="Center"/>

                    <!-- End Date Label -->
                    <TextBlock Grid.Column="2"
                               Text="End Date:"
                               FontWeight="Bold"
                               FontSize="13"
                               Margin="10,0"
                               VerticalAlignment="Center"
                               FontFamily="Microsoft Sans Serif"/>

                    <!-- End Date Picker -->
                    <DatePicker x:Name="Dtpenddate"
                                Grid.Column="3"
                                Width="135"
                                Height="26"
                                VerticalAlignment="Center"/>

                    <Button x:Name="Btngetdata"
                     Grid.Column="4"
                     Content="Go"
                     Width="82"
                     Height="30"                                 
                     Margin="10,0" 
                     Click="Btngetdata_Click" 
                     FontFamily="Microsoft Sans Serif"           
                     Style="{StaticResource FixedBlueButtonStyle}"/>

                    <StackPanel Grid.Column="6"
                         Orientation="Horizontal"
                         HorizontalAlignment="Right"
                         Margin="0,0,10,0">

                        <TextBlock Text="Amount:"
                            FontWeight="Bold"
                            VerticalAlignment="Center"
                            FontFamily="Microsoft Sans Serif"   
                            FontSize="13"          
                            Margin="0,0,5,0"/>

                        <TextBlock x:Name="Lblprintamount"
                            Text=""
                            VerticalAlignment="Center"
                            Visibility="Collapsed"
                            FontFamily="Microsoft Sans Serif"   
                            FontSize="13"       
                            Margin="0,0,15,0"/>

                        <Button x:Name="BtnExportExcel" Width="30" Height="30" Margin="5,0" Background="Transparent" BorderThickness="0" Cursor="Hand">
                            <Image Source="/" RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Button>
                        <Button x:Name="BtnExportPdf" Width="30" Height="30" Margin="5,0" Background="Transparent" BorderThickness="0" Cursor="Hand">
                            <Image Source="/" RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- DataGrid -->
                <DataGrid x:Name="DgvLedgerRecord"
                   Style="{StaticResource CustomDataGrid}"       
                   Margin="3,62,3,3"
                   AutoGenerateColumns="True"
                   IsReadOnly="True"
                   SelectionMode="Single"
                   CanUserSortColumns="False"      
                   HeadersVisibility="Column"
                   GridLinesVisibility="All"
                   SelectionUnit="FullRow"
                   CanUserAddRows="False"
                   CanUserDeleteRows="False"
                   VerticalScrollBarVisibility="Auto"                  
                   BorderThickness="0"/>

               <TextBlock x:Name="TxtNoData"
               Text="No Data Available"
               FontSize="15"
               FontWeight="Bold"
               Foreground="Black"
               Visibility="Collapsed"
               HorizontalAlignment="Center"
               VerticalAlignment="Center" Margin="0,0,0,250" FontFamily="Microsoft Sans Serif"/>
            </Grid>
        </Border>
    </Grid>
    
</UserControl>
