<UserControl x:Class="ClientDesktop.View.Navigation.NavigationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:ClientDesktop.ViewModel;assembly=ClientDesktop.ViewModel"
             xmlns:models="clr-namespace:ClientDesktop.Core.Models;assembly=ClientDesktop.Core">

    <UserControl.Resources>
        <SolidColorBrush x:Key="TextDark" Color="#000000"/>
        <SolidColorBrush x:Key="TextGreen" Color="#0D9E5E"/>
        <SolidColorBrush x:Key="TextBlue" Color="#1E7EB3"/>
        <SolidColorBrush x:Key="ActiveSelectedBg" Color="#0078D7"/>
        <SolidColorBrush x:Key="InactiveSelectedBg" Color="#66A3D1"/>

        <!-- Common Style for StackPanel inside Headers -->
        <Style TargetType="StackPanel" x:Key="HeaderPanelStyle">
            <Setter Property="Orientation" Value="Horizontal"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <!-- Common Style for TextBlocks -->
        <Style TargetType="TextBlock" x:Key="ItemTextStyle">
            <Setter Property="Margin" Value="6,0,2,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- Toggle Button Style for WPF Default Triangle Arrow -->
        <Style x:Key="ExpandCollapseToggleStyle" TargetType="ToggleButton">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Width" Value="16"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="Transparent" Padding="4">
                            <Path x:Name="ExpandPath" Fill="#666" Data="M 0,0 L 4,4 L 0,8 Z" 
                                  HorizontalAlignment="Center" VerticalAlignment="Center" SnapsToDevicePixels="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ExpandPath" Property="Fill" Value="#222"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ExpandPath" Property="Data" Value="M 0,0 L 8,0 L 4,4 Z"/>
                                <Setter TargetName="ExpandPath" Property="Fill" Value="#444"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="ExpandPath" Property="Fill" Value="#111"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom TreeViewItem Style -->
        <Style TargetType="TreeViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="2,1"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>

                            <Grid x:Name="HeaderGrid" Background="Transparent" HorizontalAlignment="Left">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="18"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <ToggleButton x:Name="Expander" Style="{StaticResource ExpandCollapseToggleStyle}" 
                                              IsChecked="{Binding Path=IsExpanded, RelativeSource={RelativeSource TemplatedParent}}" 
                                              ClickMode="Press" Grid.Column="0"/>

                                <Border x:Name="Bd" Grid.Column="1" Background="{TemplateBinding Background}" 
                                        BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" 
                                        Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True" CornerRadius="3" Margin="0,1">
                                    <ContentPresenter x:Name="PART_Header" ContentSource="Header" 
                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                                      SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                </Border>
                            </Grid>

                            <ItemsPresenter x:Name="ItemsHost" Grid.Row="1" Margin="15,0,0,0"/>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="False">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" SourceName="Bd"/>
                                    <Condition Property="IsSelected" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#F5F5F5"/>
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True"/>
                                    <Condition Property="IsSelectionActive" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource ActiveSelectedBg}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True"/>
                                    <Condition Property="IsSelectionActive" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource InactiveSelectedBg}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dynamic DataTemplates for Server & User Nodes (Using "models" namespace) -->
        <HierarchicalDataTemplate DataType="{x:Type models:ServerNode}" ItemsSource="{Binding Users}">
            <StackPanel Style="{StaticResource HeaderPanelStyle}">
                <Border Background="#1C0D4F" Width="15" Height="15" CornerRadius="3">
                    <TextBlock Text="{Binding IconText}" Foreground="#F0338F" FontWeight="Bold" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-2,0,0"/>
                </Border>
                <TextBlock Text="{Binding ServerName}" Style="{StaticResource ItemTextStyle}"/>
            </StackPanel>
        </HierarchicalDataTemplate>

        <DataTemplate DataType="{x:Type models:NavigationNode}">
            <StackPanel Style="{StaticResource HeaderPanelStyle}" Cursor="Hand">
                <Path Data="M12,4A4,4 0 1,1 8,0A4,4 0 0,1 12,4 M15,14C15,12 12,10 8,10C4,10 1,12 1,14L1,16L15,16 Z" Fill="LimeGreen" Width="12" Height="12" Stretch="Fill"/>
                <TextBlock Text="{Binding DisplayName}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource ItemTextStyle}">
                            <Setter Property="Foreground" Value="Black"/>
                            <Setter Property="FontWeight" Value="Normal"/>
                            <!-- IsActiveUser Triggers -->
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsActiveUser}" Value="True">
                                    <Setter Property="Foreground" Value="#1E7EB3"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=TreeViewItem}, Path=IsSelected}" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="2,4,0,0">
        <TreeView BorderThickness="0" Background="Transparent" PreviewMouseLeftButtonUp="TreeView_PreviewMouseLeftButtonUp">
            <TreeViewItem IsExpanded="False" ItemsSource="{Binding Servers}">
                <TreeViewItem.ItemContainerStyle>
                    <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                        <Setter Property="IsExpanded" Value="False"/>
                    </Style>
                </TreeViewItem.ItemContainerStyle>
                <TreeViewItem.Header>
                    <StackPanel Style="{StaticResource HeaderPanelStyle}">
                        <Path Data="M12,4A4,4 0 1,1 8,0A4,4 0 0,1 12,4 M15,14C15,12 12,10 8,10C4,10 1,12 1,14L1,16L15,16 Z M20,4A3,3 0 1,1 17,1A3,3 0 0,1 20,4 M23,14C23,12.3 20.8,10.8 17.5,10.2C18.4,11.2 19,12.5 19,14L19,16L23,16 Z" Fill="LimeGreen" Width="16" Height="12" Stretch="Fill"/>
                        <TextBlock Text="Accounts" Style="{StaticResource ItemTextStyle}"/>
                    </StackPanel>
                </TreeViewItem.Header>
            </TreeViewItem>

            <!-- 2. BAN SCRIPT -->
            <TreeViewItem Tag="BanScript">
                <TreeViewItem.Header>
                    <StackPanel Style="{StaticResource HeaderPanelStyle}" Cursor="Hand">
                        <Grid Width="16" Height="16">
                            <Border Width="14" Height="11" Background="#F4C20D" BorderBrush="Black" BorderThickness="1.5" CornerRadius="2">
                                <TextBlock Text="$" Foreground="#C2960A" FontWeight="Bold" FontSize="9" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-1,0,0"/>
                            </Border>
                            <Line X1="0" Y1="0" X2="16" Y2="16" Stroke="Black" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                        </Grid>
                        <TextBlock Text="Ban Script" Style="{StaticResource ItemTextStyle}"/>
                    </StackPanel>
                </TreeViewItem.Header>
            </TreeViewItem>

            <!-- 3. INVOICE -->
            <TreeViewItem Tag="Invoice">
                <TreeViewItem.Header>
                    <StackPanel Style="{StaticResource HeaderPanelStyle}" Cursor="Hand">
                        <Grid Width="16" Height="16">
                            <Path Data="M4,2 L14,2 L14,16 L4,16 Z" Fill="#5C9BD3"/>
                            <Rectangle Fill="White" Width="6" Height="2" Margin="0,-10,0,0"/>
                            <Ellipse Fill="#FF9900" Width="8" Height="8" Margin="8,8,0,0"/>
                        </Grid>
                        <TextBlock Text="Invoice" Style="{StaticResource ItemTextStyle}"/>
                    </StackPanel>
                </TreeViewItem.Header>
            </TreeViewItem>

            <!-- 4. LEDGER -->
            <TreeViewItem Tag="Ledger">
                <TreeViewItem.Header>
                    <StackPanel Style="{StaticResource HeaderPanelStyle}" Cursor="Hand">
                        <Border Background="#F4C261" Width="16" Height="16" CornerRadius="2">
                            <Grid Margin="2">
                                <Rectangle Fill="White" Height="3" VerticalAlignment="Top"/>
                                <UniformGrid Rows="2" Columns="3" Margin="0,5,0,0">
                                    <Rectangle Fill="White" Margin="0.5"/>
                                    <Rectangle Fill="White" Margin="0.5"/>
                                    <Rectangle Fill="White" Margin="0.5"/>
                                    <Rectangle Fill="White" Margin="0.5"/>
                                    <Rectangle Fill="White" Margin="0.5"/>
                                    <Rectangle Fill="White" Margin="0.5"/>
                                </UniformGrid>
                            </Grid>
                        </Border>
                        <TextBlock Text="Ledger" Style="{StaticResource ItemTextStyle}"/>
                    </StackPanel>
                </TreeViewItem.Header>
            </TreeViewItem>

            <!-- 5. FEEDBACK -->
            <TreeViewItem Tag="Feedback">
                <TreeViewItem.Header>
                    <StackPanel Style="{StaticResource HeaderPanelStyle}" Cursor="Hand">
                        <Grid Width="16" Height="16">
                            <Path Data="M2,2 L16,2 L16,12 L10,12 L6,16 L6,12 L2,12 Z" Fill="#E0E0E0" Stroke="Black" StrokeThickness="1" Stretch="Fill"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,-2,0,0">
                                <Ellipse Fill="Yellow" Width="4" Height="4" Margin="1"/>
                                <Ellipse Fill="Red" Width="4" Height="4" Margin="1"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="Feedback" Style="{StaticResource ItemTextStyle}"/>
                    </StackPanel>
                </TreeViewItem.Header>
            </TreeViewItem>

            <!-- 6. DISCLAIMER -->
            <TreeViewItem Tag="Disclaimer">
                <TreeViewItem.Header>
                    <StackPanel Style="{StaticResource HeaderPanelStyle}" Cursor="Hand">
                        <Grid Width="16" Height="16">
                            <Path Data="M8,0 L16,14 L0,14 Z" Fill="#A2C0D4" Stretch="Fill"/>
                            <TextBlock Text="!" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,2,0,0" FontSize="10"/>
                        </Grid>
                        <TextBlock Text="Disclaimer" Style="{StaticResource ItemTextStyle}"/>
                    </StackPanel>
                </TreeViewItem.Header>
            </TreeViewItem>

        </TreeView>
    </Grid>
</UserControl>
