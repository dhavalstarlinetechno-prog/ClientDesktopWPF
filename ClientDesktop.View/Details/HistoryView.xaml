<UserControl x:Class="ClientDesktop.View.Details.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:ClientDesktop.ViewModel;assembly=ClientDesktop.ViewModel" 
             xmlns:conv="clr-namespace:ClientDesktop.View.Converters"
             xmlns:enum="clr-namespace:ClientDesktop.Core.Enums;assembly=ClientDesktop.Core"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d" 
             d:DesignHeight="400" d:DesignWidth="1200">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:SideConverter x:Key="SideConverter"/>
        <conv:UtcToIstConverter x:Key="UtcToIstConverter"/>
        <conv:StringTruncateConverter x:Key="TruncateConverter"/>
        <conv:EnumToDescriptionConverter x:Key="EnumToDescriptionConverter" />
        <conv:AmountFormatConverter x:Key="AmountConverter"/>
        <Style x:Key="HeaderLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="White">
        <Grid.ContextMenu>
            <ContextMenu>
                <MenuItem x:Name="MenuDeals" Header="Deals" Command="{Binding ChangeViewCommand}" CommandParameter="Deals" IsCheckable="True" IsChecked="{Binding IsDealsChecked, Mode=OneWay}"/>
                <MenuItem x:Name="MenuOrders" Header="Orders" Command="{Binding ChangeViewCommand}" CommandParameter="Orders" IsCheckable="True" IsChecked="{Binding IsOrdersChecked, Mode=OneWay}"/>
                <MenuItem x:Name="MenuPosition" Header="Position" Command="{Binding ChangeViewCommand}" CommandParameter="Position" IsCheckable="True" IsChecked="{Binding IsPositionChecked, Mode=OneWay}"/>
            </ContextMenu>
        </Grid.ContextMenu>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" Padding="0,5">
            <Grid>
                <Grid x:Name="HeaderDealsOrders" Visibility="{Binding DealsGridVisibility}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="0.8*"/>
                        <ColumnDefinition Width="0.6*"/>
                        <ColumnDefinition Width="0.6*"/>
                        <ColumnDefinition Width="0.8*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="0.8*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="lblTitleDealsOrders" Grid.Column="0" Grid.ColumnSpan="3" 
                               Text="{Binding CurrentViewTitle}" Style="{StaticResource HeaderLabel}" 
                               FontSize="14" Margin="10,0,0,0"/>
                    <ComboBox x:Name="FilterSymbol" ItemsSource="{Binding AvailableSymbols}" SelectedItem="{Binding SelectedSymbol, Mode=TwoWay}" Style="{StaticResource CustomComboBoxStyle}" ItemContainerStyle="{StaticResource CustomComboBoxItemStyle}" Grid.Column="3" Margin="1" />
                    <ComboBox x:Name="FilterExecution" ItemsSource="{Binding AvailableExecutions}" SelectedItem="{Binding SelectedExecution, Mode=TwoWay}" Style="{StaticResource CustomComboBoxStyle}" ItemContainerStyle="{StaticResource CustomComboBoxItemStyle}" Grid.Column="4" Margin="1" />
                    <ComboBox x:Name="FilterType" ItemsSource="{Binding AvailableTypes}" SelectedItem="{Binding SelectedType, Mode=TwoWay}" Style="{StaticResource CustomComboBoxStyle}" ItemContainerStyle="{StaticResource CustomComboBoxItemStyle}" Grid.Column="5" Margin="1" />
                    <ComboBox x:Name="FilterEntry" ItemsSource="{Binding AvailableEntries}" SelectedItem="{Binding SelectedEntry, Mode=TwoWay}" Style="{StaticResource CustomComboBoxStyle}" ItemContainerStyle="{StaticResource CustomComboBoxItemStyle}" Grid.Column="6" Margin="1" />
                </Grid>

                <Grid x:Name="HeaderPosition" Visibility="{Binding PositionGridVisibility}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="0.6*"/>
                        <ColumnDefinition Width="0.8*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="0.8*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Position" Grid.Column="0" Style="{StaticResource HeaderLabel}" FontSize="14" Margin="10,0,0,0"/>
                    <ComboBox Grid.Column="6" x:Name="FilterPosSymbol" ItemsSource="{Binding AvailablePosSymbols}" SelectedItem="{Binding SelectedPosSymbol, Mode=TwoWay}" Style="{StaticResource CustomComboBoxStyle}" ItemContainerStyle="{StaticResource CustomComboBoxItemStyle}" />
                </Grid>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,10,0" VerticalAlignment="Center">
                    <ComboBox x:Name="PeriodCombo"
                                ItemsSource="{Binding EnumPeriods}"
                                SelectedItem="{Binding SelectedPeriod, Mode=TwoWay}"
                                Width="120"
                                Margin="5,0"
                                ItemContainerStyle="{StaticResource CustomComboBoxItemStyle}"
                                Style="{StaticResource CustomComboBoxStyle}">

                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Path=., Converter={StaticResource EnumToDescriptionConverter}}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <DatePicker x:Name="StartDatePicker" SelectedDate="{Binding StartDate, Mode=TwoWay}" Width="130" Style="{StaticResource CustomDatePickerStyle}"/>
                    <TextBlock Text="-" Style="{StaticResource HeaderLabel}"/>
                    <DatePicker x:Name="EndDatePicker" SelectedDate="{Binding EndDate, Mode=TwoWay}" Width="130" Style="{StaticResource CustomDatePickerStyle}"/>

                    <!-- Save Profile Button -->
                    <Button Content="Request" Style="{StaticResource CommonActionButtonStyle}" Width="90" Margin="5,0,5,0" Height="22" Background="#42A5F5" Foreground="White" Command="{Binding RequestCommand}"/>
                    <Button ToolTip="Export to Excel" Width="25" Height="25" Margin="0,0,0,3" Background="Transparent" BorderThickness="0" Cursor="Hand" Command="{Binding ExportExcelCommand}">
                        <Viewbox Width="23" Height="22">
                            <Grid>
                                <Path Fill="#217346" Data="M4,4 H20 A2,2 0 0 1 22,6 V26 A2,2 0 0 1 20,28 H4 A2,2 0 0 1 2,26 V6 A2,2 0 0 1 4,4 Z" />
                                <Path Fill="#107C41" Opacity="0.5" Data="M22,15 V26 A2,2 0 0 1 20,28 H12 L22,15 Z" />
                                <Path Stroke="White" StrokeThickness="0.8" Opacity="0.3" Data="M12,8 H18 M12,12 H18 M12,16 H18 M12,20 H18 M12,24 H18 M11,8 V24" />
                                <Border Background="#185C37" CornerRadius="2" Margin="0,4,10,4" HorizontalAlignment="Left" Width="14" Height="14">
                                    <Grid>
                                        <Path Fill="White" Opacity="0.1" Data="M0,0 H14 L0,14 Z" />
                                        <TextBlock Text="X" Foreground="White" FontSize="10" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="Segoe UI" />
                            </Grid>
                                </Border>
                            </Grid>
                        </Viewbox>
                    </Button>
                    <Button ToolTip="Export to PDF" Width="25" Height="25" Margin="0,0,0,3" Background="Transparent" BorderThickness="0" Cursor="Hand" Command="{Binding ExportPdfCommand}">
                        <Viewbox Width="23" Height="22">
                            <Grid>
                                <Path Fill="#B30B00" Data="M4,4 H20 A2,2 0 0 1 22,6 V26 A2,2 0 0 1 20,28 H4 A2,2 0 0 1 2,26 V6 A2,2 0 0 1 4,4 Z" />
                                <Path Fill="#7A0800" Opacity="0.4" Data="M22,15 V26 A2,2 0 0 1 20,28 H12 L22,15 Z" />
                                <Path Stroke="White" StrokeThickness="1" Opacity="0.3" Data="M6,10 H16 M6,14 H18 M6,18 H18 M6,22 H12" />
                                <Border Background="#E52521" CornerRadius="2" Margin="8,10,0,4" VerticalAlignment="Bottom" HorizontalAlignment="Right" Padding="2,0">
                                    <TextBlock Text="PDF" Foreground="White" FontSize="7" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="Segoe UI" />
                                </Border>
                            </Grid>
                        </Viewbox>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">

            <DataGrid x:Name="GridDealsOrders" 
                      ItemsSource="{Binding HistoryItems}" 
                      Visibility="{Binding DealsGridVisibility}"
                      Style="{StaticResource CustomDataGrid}" 
                      IsReadOnly="True"
                      AutoGenerateColumns="False" 
                      CanUserAddRows="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="All"
                      BorderThickness="0"
                      RowHeaderWidth="0"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      AllowDrop="True"
                      CanUserSortColumns="True"
                      Sorting="GridDealsOrders_Sorting">

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="White"/>
                        <Setter Property="Foreground" Value="Black"/>
                        <Setter Property="FontWeight" Value="Normal"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridRow">
                                    <Border x:Name="DGR_Border"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            Background="{TemplateBinding Background}"
                                            SnapsToDevicePixels="True">
                                        <Grid>
                                            <DataGridCellsPresenter x:Name="CellsPresenter"
                                                    ItemsPanel="{TemplateBinding ItemsPanel}"
                                                    SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                            <TextBlock x:Name="FooterText"
                                                       Text="{Binding Comment}"
                                                       FontWeight="Bold"
                                                       VerticalAlignment="Center"
                                                       Margin="5,0,0,0"
                                                       Width="600"
                                                       HorizontalAlignment="Left"
                                                       TextWrapping="NoWrap"
                                                       Visibility="Collapsed"
                                                       Panel.ZIndex="1"/>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                            <Setter TargetName="DGR_Border" Property="Background" Value="#EEEEEE"/>
                                        </Trigger>
                                        <DataTrigger Binding="{Binding RefId}" Value="FOOTER">
                                            <Setter TargetName="DGR_Border" Property="Background" Value="#D3D3D3"/>
                                            <Setter TargetName="DGR_Border" Property="BorderThickness" Value="0"/>
                                            <Setter TargetName="FooterText"  Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="DGR_Border" Property="Background" Value="#0078D7"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Time" Width="1.5*" SortMemberPath="CreatedOn">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Margin="0,0,5,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding CreatedOn, Converter={StaticResource UtcToIstConverter}, ConverterParameter='dd/MM/yy HH:mm'}"/>
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RefId}" Value="FOOTER">
                                                    <Setter Property="Text" Value=""/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Deal Id" Width="*" SortMemberPath="RefId">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock VerticalAlignment="Center" ToolTip="{Binding RefId}" Margin="5,0,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{Binding RefId, Converter={StaticResource TruncateConverter}}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding RefId}" Value="FOOTER">
                                                        <Setter Property="Text" Value=""/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <Button Margin="5,0,0,0" Click="CopyId_Click" Tag="{Binding RefId}" Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="Copy to Clipboard">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <Trigger Property="Tag" Value="FOOTER">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <Path Data="M19,21H8V7H19M19,5H8A2,2 0 0,0 6,7V21A2,2 0 0,0 8,23H19A2,2 0 0,0 21,21V7A2,2 0 0,0 19,5M16,1H4A2,2 0 0,0 2,3V17H4V3H16V1Z" Fill="#555" Stretch="Uniform" Height="12" Width="12"/>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Position Id" Width="*" SortMemberPath="PositionId">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock VerticalAlignment="Center" ToolTip="{Binding PositionId}" Margin="5,0,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{Binding PositionId, Converter={StaticResource TruncateConverter}, TargetNullValue='--', FallbackValue='--'}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding RefId}" Value="FOOTER">
                                                        <Setter Property="Text" Value=""/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <Button Margin="5,0,0,0" Click="CopyId_Click" Tag="{Binding PositionId}" Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="Copy Id">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <Trigger Property="Tag" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </Trigger>
                                                    <Trigger Property="Tag" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </Trigger>
                                                    <Trigger Property="Tag" Value="FOOTER">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <Path Data="M19,21H8V7H19M19,5H8A2,2 0 0,0 6,7V21A2,2 0 0,0 8,23H19A2,2 0 0,0 21,21V7A2,2 0 0,0 19,5M16,1H4A2,2 0 0,0 2,3V17H4V3H16V1Z" Fill="#555" Stretch="Uniform" Height="12" Width="12"/>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Symbol" Width="*" SortMemberPath="SymbolName">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Margin="5,0,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding SymbolName}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RefId}" Value="FOOTER">
                                                    <Setter Property="Text" Value=""/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Execution" Width="0.8*" SortMemberPath="OrderType">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Margin="5,0,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding OrderType}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RefId}" Value="FOOTER">
                                                    <Setter Property="Text" Value=""/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Type" Width="0.6*" SortMemberPath="Side">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Margin="5,0,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding Side}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RefId}" Value="FOOTER">
                                                    <Setter Property="Text" Value=""/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Entry" Width="0.6*" SortMemberPath="DealType">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Margin="5,0,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding DealType}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RefId}" Value="FOOTER">
                                                    <Setter Property="Text" Value=""/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Volume" Width="0.8*" SortMemberPath="Volume">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Margin="0,0,5,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding Volume}"/>
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RefId}" Value="FOOTER">
                                                    <Setter Property="Text" Value=""/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Price" Width="*" SortMemberPath="Price">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Margin="0,0,5,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding DisplayPrice}"/>
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RefId}" Value="FOOTER">
                                                    <Setter Property="Text" Value=""/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Comm." Width="0.8*" SortMemberPath="UplineCommission">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock HorizontalAlignment="Right" Margin="0,0,5,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text"       Value="{Binding UplineCommission, Converter={StaticResource AmountConverter}}"/>
                                            <Setter Property="FontWeight" Value="Normal"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RefId}" Value="FOOTER">
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Profit" Width="*" SortMemberPath="Pnl">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock HorizontalAlignment="Right" Margin="0,0,5,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text"       Value="{Binding Pnl, Converter={StaticResource AmountConverter}}"/>
                                            <Setter Property="FontWeight" Value="Normal"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RefId}" Value="FOOTER">
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Comment" Width="2*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Margin="5,0,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding Comment}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RefId}" Value="FOOTER">
                                                    <Setter Property="Text" Value=""/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>
            </DataGrid>

            <DataGrid x:Name="GridPosition" 
                      ItemsSource="{Binding PositionHistoryItems}" 
                      Visibility="{Binding PositionGridVisibility}"
                      Style="{StaticResource CustomDataGrid}" 
                      IsReadOnly="True"
                      AutoGenerateColumns="False" 
                      CanUserAddRows="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="All"
                      BorderThickness="0"
                      RowHeaderWidth="0"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      AllowDrop="True"
                      CanUserSortColumns="True"
                      Sorting="GridPosition_Sorting">

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="White"/>
                        <Setter Property="Foreground" Value="Black"/>
                        <Setter Property="FontWeight" Value="Normal"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridRow">
                                    <Border x:Name="DGR_Border"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            Background="{TemplateBinding Background}"
                                            SnapsToDevicePixels="True">
                                        <Grid>
                                            <DataGridCellsPresenter x:Name="CellsPresenter"
                                                    ItemsPanel="{TemplateBinding ItemsPanel}"
                                                    SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                            <TextBlock x:Name="FooterText"
                                                       Text="{Binding Comment}"
                                                       FontWeight="Bold"
                                                       VerticalAlignment="Center"
                                                       Margin="5,0,0,0"
                                                       Width="600"
                                                       HorizontalAlignment="Left"
                                                       TextWrapping="NoWrap"
                                                       Visibility="Collapsed"
                                                       Panel.ZIndex="1"/>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                            <Setter TargetName="DGR_Border" Property="Background" Value="#EEEEEE"/>
                                        </Trigger>
                                        <DataTrigger Binding="{Binding RefId}" Value="FOOTER">
                                            <Setter TargetName="DGR_Border"  Property="Background" Value="#D3D3D3"/>
                                            <Setter TargetName="DGR_Border"  Property="BorderThickness" Value="0"/>
                                            <Setter TargetName="FooterText"  Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="DGR_Border" Property="Background" Value="#0078D7"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>

                    <DataGridTemplateColumn Header="Time" Width="1.2*" SortMemberPath="UpdatedAt">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Margin="0,0,5,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding UpdatedAt, Converter={StaticResource UtcToIstConverter}}"/>
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RefId}" Value="FOOTER">
                                                    <Setter Property="Text" Value=""/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Last Out Time" Width="1.2*" SortMemberPath="LastOutAt">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Margin="0,0,5,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding LastOutAt, Converter={StaticResource UtcToIstConverter}, TargetNullValue='--'}"/>
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RefId}" Value="FOOTER">
                                                    <Setter Property="Text" Value=""/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Position Id" Width="*" SortMemberPath="RefId">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock VerticalAlignment="Center" ToolTip="{Binding RefId}" Margin="5,0,0,0">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{Binding RefId, Converter={StaticResource TruncateConverter}}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding RefId}" Value="FOOTER">
                                                        <Setter Property="Text" Value=""/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <Button Margin="5,0,0,0" Click="CopyId_Click" Tag="{Binding RefId}" Background="Transparent" BorderThickness="0" Cursor="Hand" ToolTip="Copy to Clipboard">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <Trigger Property="Tag" Value="FOOTER">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <Path Data="M19,21H8V7H19M19,5H8A2,2 0 0,0 6,7V21A2,2 0 0,0 8,23H19A2,2 0 0,0 21,21V7A2,2 0 0,0 19,5M16,1H4A2,2 0 0,0 2,3V17H4V3H16V1Z" Fill="#555" Stretch="Uniform" Height="12" Width="12"/>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Type" Width="0.6*" SortMemberPath="Side">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Margin="5,0,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding Side, Converter={StaticResource SideConverter}}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RefId}" Value="FOOTER">
                                                    <Setter Property="Text" Value=""/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Volume" Width="0.8*" SortMemberPath="VolumeDisplay">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Margin="0,0,5,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding VolumeDisplay}"/>
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RefId}" Value="FOOTER">
                                                    <Setter Property="Text" Value=""/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Symbol" Width="*" SortMemberPath="SymbolName">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Margin="5,0,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding SymbolName}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RefId}" Value="FOOTER">
                                                    <Setter Property="Text" Value=""/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Price" Width="*" SortMemberPath="AveragePrice">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Margin="0,0,5,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding DisplayAveragePrice}"/>
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RefId}" Value="FOOTER">
                                                    <Setter Property="Text" Value=""/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Comm." Width="0.8*" SortMemberPath="UplineCommission">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock HorizontalAlignment="Right" Margin="0,0,5,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text"       Value="{Binding UplineCommission, Converter={StaticResource AmountConverter}}"/>
                                            <Setter Property="FontWeight" Value="Normal"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RefId}" Value="FOOTER">
                                                    <Setter Property="Text"       Value="{Binding Fee}"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Profit" Width="*" SortMemberPath="Pnl">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock HorizontalAlignment="Right" Margin="0,0,5,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text"       Value="{Binding Pnl, Converter={StaticResource AmountConverter}}"/>
                                            <Setter Property="FontWeight" Value="Normal"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RefId}" Value="FOOTER">
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Comment" Width="2*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Margin="5,0,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding Comment}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RefId}" Value="FOOTER">
                                                    <Setter Property="Text" Value=""/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>
            </DataGrid>

            <TextBlock x:Name="NoDataLabel" Text="No data available" FontSize="24" Foreground="Gray" HorizontalAlignment="Center" VerticalAlignment="Center"
                       Visibility="{Binding HasNoData, Converter={StaticResource BoolToVis}}"/>
        </Grid>
    </Grid>
</UserControl>