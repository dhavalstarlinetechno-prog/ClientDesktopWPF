                        <DataGridTemplateColumn Header="Symbol" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Path Data="{StaticResource FolderGeometry}"
                                        Width="16"
                                        Height="16"
                                        Fill="#f4b400"
                                        Margin="0,0,6,0"
                                        Stretch="Uniform">
                                            <Path.Style>
                                                <Style TargetType="Path">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RouteType}" Value="Folder">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Path.Style>
                                        </Path>
                                        <Border Width="16" Height="16" 
                                            Background="#FFD700" 
                                            CornerRadius="1" 
                                            Margin="0,0,6,0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RouteType}" Value="Symbol">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Path Data="{StaticResource SymbolGeometry}"
                                              Width="12" Height="12"
                                              Stroke="#8B4513" 
                                              StrokeThickness="1.5"
                                              Stretch="Uniform"
                                              HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="{Binding Symbol}"
                                            VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Expiry" Binding="{Binding Expiry}" Width="*"/>
                        <DataGridTextColumn Header="Expiry close" Binding="{Binding ExpiryClose}" Width="*"/>
                        <DataGridTextColumn Header="Parent ID" Binding="{Binding ParentId}" Width="*" Visibility="Collapsed"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding SymbolStatus}" Width="*" Visibility="Collapsed"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
