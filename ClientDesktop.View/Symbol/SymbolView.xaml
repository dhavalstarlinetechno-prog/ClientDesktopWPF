<UserControl x:Class="ClientDesktop.View.Symbol.SymbolView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:local="clr-namespace:ClientDesktop.View.Symbol"
             mc:Ignorable="d" 
             Height="550" Width="1150" Loaded="UserControl_Loaded">
    <UserControl.Resources>
        <Geometry x:Key="FolderGeometry">
            M10,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8C22,6.89 21.1,6 20,6H12L10,4Z
        </Geometry>
        <Geometry x:Key="SymbolGeometry">
            M12 2V22M17 5H9.5C8.57174 5 7.6815 5.36875 7.02513 6.02513C6.36875 6.6815 6 7.57174 6 8.5C6 9.42826 6.36875 10.3185 7.02513 10.9749C7.6815 11.6313 8.57174 12 9.5 12H14.5C15.4283 12 16.3185 12.3687 16.9749 13.0251C17.6313 13.6815 18 14.5717 18 15.5C18 16.4283 17.6313 17.3185 16.9749 17.9749C16.3185 18.6313 15.4283 19 14.5 19H7
        </Geometry>
        <Geometry x:Key="SearchGeometry">
            M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z
        </Geometry>
        <Style x:Key="FolderTreeItemStyle" TargetType="TreeViewItem">
            <Setter Property="HeaderTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource FolderGeometry}"
                              Fill="#f4b400"
                              Width="16"
                              Height="16"
                              Stretch="Uniform"
                              Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="Black"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="CornflowerBlue"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="110"/>
        </Grid.ColumnDefinitions>
        <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="0" 
            BorderBrush="Gray" BorderThickness="1" Margin="0,0,10,0">
            <TreeView x:Name="SymbolTreeview" 
                  FontSize="12" 
                  BorderThickness="0" 
                  SelectedItemChanged="SymbolTreeview_SelectedItemChanged"
                  TreeViewItem.Expanded="SymbolTreeview_Expanded"/>
        </Border>
        <Grid Grid.Row="0" Grid.Column="1" HorizontalAlignment="Left" Margin="0,0,0,10">
            <TextBox x:Name="Txtsearch" Width="400" Height="25" 
         VerticalContentAlignment="Center" 
         Padding="25,0,5,0" TextChanged="Txtsearch_TextChanged">
                <TextBox.Background>
                    <VisualBrush Stretch="None" AlignmentX="Left">
                        <VisualBrush.Visual>
                            <Viewbox Width="16" Height="16" Margin="5,0,5,0">
                                <Path Data="{StaticResource SearchGeometry}" Fill="Black" Stretch="Uniform"/>
                            </Viewbox>
                        </VisualBrush.Visual>
                    </VisualBrush>
                </TextBox.Background>
            </TextBox>
        </Grid>
        <StackPanel Grid.Row="1" Grid.Column="2" VerticalAlignment="Top">
            <Button x:Name="BtnShow" Content="Show" Height="30" Margin="0,0,0,10" 
                Background="#3498db" Foreground="White" FontWeight="Bold" Click="BtnShow_Click"/>
            <Button x:Name="Btnhide" Content="Hide" Height="30" 
                Background="#3498db" Foreground="White" FontWeight="Bold" Click="Btnhide_Click"/>
        </StackPanel>
