                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="1.5*"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" BorderBrush="Gray" BorderThickness="0">
                <DataGrid x:Name="DgvSymbols" 
                      Style="{StaticResource CustomDataGrid}"    
                      AutoGenerateColumns="False" 
                      HeadersVisibility="Column" 
                      GridLinesVisibility="All" 
                      Background="White"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserResizeRows="False"
                      RowHeight="24"
                      BorderThickness="0" 
                      SelectionUnit="FullRow" MouseDoubleClick="DgvSymbols_MouseDoubleClick" PreviewMouseLeftButtonDown="DgvSymbols_PreviewMouseLeftButtonDown">
