<UserControl x:Class="ClientDesktop.View.Delete.DeleteView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="250" d:DesignWidth="400"
             Background="Transparent">

    <UserControl.Resources>
        <Style x:Key="SubmitButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#27AE60" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="1" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#B4B4B4" />
                    <Setter Property="Foreground" Value="DarkGray" />
                    <Setter Property="BorderBrush" Value="Silver" />
                    <Setter Property="Cursor" Value="No" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CancelButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Red" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="White" CornerRadius="8" Width="400" Height="250" 
            BorderBrush="LightGray" BorderThickness="1">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">

            <Viewbox Width="80" Height="80" Margin="0,0,0,15">
                <Path Fill="#E74C3C" Stretch="Uniform"
          Data="M 10 2 L 9 3 L 4 3 L 4 5 L 5 5 L 5 20 C 5 20.552 5.448 21 6 21 L 18 21 C 18.552 21 19 20.552 19 20 L 19 5 L 20 5 L 20 3 L 15 3 L 14 2 L 10 2 z M 7 5 L 17 5 L 17 19 L 7 19 L 7 5 z M 9 7 L 9 17 L 11 17 L 11 7 L 9 7 z M 13 7 L 13 17 L 15 17 L 15 7 L 13 7 z" />
            </Viewbox>
            <TextBlock Text="You want to delete?!" 
                       FontSize="14" TextAlignment="Center" Margin="0,0,0,10"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                <TextBlock Text="{Binding RandomString}" 
                           FontWeight="Bold" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>

                <TextBox Text="{Binding UserInput, UpdateSourceTrigger=PropertyChanged}" 
                         Width="140" Height="25" FontSize="14" VerticalContentAlignment="Center"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="Submit" 
                        IsDefault="True"
                        Command="{Binding SubmitCommand}" 
                        Style="{StaticResource SubmitButtonStyle}" 
                        Width="100" Height="33" Margin="0,0,10,0"/>

                <Button Content="Cancel" 
                        IsCancel="True"
                        Command="{Binding CancelCommand}" 
                        Style="{StaticResource CancelButtonStyle}" 
                        Width="100" Height="33"/>
            </StackPanel>

        </StackPanel>
    </Border>
</UserControl>