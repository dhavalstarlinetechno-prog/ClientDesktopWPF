<UserControl x:Class="ClientDesktop.View.TradeOrder.OrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="290" Width="650"
        Background="White"
        Unloaded="UserControl_Unloaded">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#444"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Medium"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="22"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="BorderBrush" Value="#CCC"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="22"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="0,0,10,0" VerticalAlignment="Top" IsEnabled="{Binding IsFormEnabled}">

            <GroupBox Header="Account Detail:" BorderBrush="#DDD" Padding="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="18"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="User Name :" Grid.Row="0" Style="{StaticResource LabelStyle}"/>
                    <TextBlock x:Name="lblUsername" Text="{Binding UserName}" Grid.Row="0" Grid.Column="1" Style="{StaticResource ValueStyle}"/>

                    <TextBlock Text="Balance :" Grid.Row="1" Style="{StaticResource LabelStyle}"/>
                    <TextBlock x:Name="lblBalance" Text="{Binding Balance}" Grid.Row="1" Grid.Column="1" Style="{StaticResource ValueStyle}"/>

                    <TextBlock Text="Credit :" Grid.Row="2" Style="{StaticResource LabelStyle}"/>
                    <TextBlock x:Name="lblCredit" Text="{Binding Credit}" Grid.Row="2" Grid.Column="1" Style="{StaticResource ValueStyle}"/>

                    <TextBlock Text="Occupied Margin :" Grid.Row="3" Style="{StaticResource LabelStyle}"/>
                    <TextBlock x:Name="lblOcupiedMargin" Text="{Binding OccupiedMargin}" Grid.Row="3" Grid.Column="1" Style="{StaticResource ValueStyle}"/>

                    <TextBlock Text="Free Margin :" Grid.Row="4" Style="{StaticResource LabelStyle}"/>
                    <TextBlock x:Name="lblFreeMargin" Text="{Binding FreeMargin}" Grid.Row="4" Grid.Column="1" Style="{StaticResource ValueStyle}"/>
                </Grid>
            </GroupBox>

            <GroupBox Header="Symbol Detail:" Margin="0,10,0,0" BorderBrush="#DDD" Padding="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="18"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Min Value :" Grid.Row="0" Style="{StaticResource LabelStyle}"/>
                    <TextBlock x:Name="lblMinValue" Text="{Binding MinValue}" Grid.Row="0" Grid.Column="1" Style="{StaticResource ValueStyle}"/>

                    <TextBlock Text="Step Value :" Grid.Row="1" Style="{StaticResource LabelStyle}"/>
                    <TextBlock x:Name="lblStepValue" Text="{Binding StepValue}" Grid.Row="1" Grid.Column="1" Style="{StaticResource ValueStyle}"/>

                    <TextBlock Text="One Value :" Grid.Row="2" Style="{StaticResource LabelStyle}"/>
                    <TextBlock x:Name="lblOneValue" Text="{Binding OneValue}" Grid.Row="2" Grid.Column="1" Style="{StaticResource ValueStyle}"/>

                    <TextBlock Text="Total Value :" Grid.Row="3" Style="{StaticResource LabelStyle}"/>
                    <TextBlock x:Name="lblTotalValue" Text="{Binding TotalValue}" Grid.Row="3" Grid.Column="1" Style="{StaticResource ValueStyle}"/>

                    <TextBlock Text="Limit Stop Value :" Grid.Row="4" Style="{StaticResource LabelStyle}"/>
                    <TextBlock x:Name="lblLimitStop" Text="{Binding LimitStopValue}" Grid.Row="4" Grid.Column="1" Style="{StaticResource ValueStyle}"/>
                </Grid>
            </GroupBox>
        </StackPanel>

        <StackPanel Grid.Column="1" Margin="8,5,0,0" VerticalAlignment="Top">

            <Grid Margin="0,0,0,8" IsEnabled="{Binding IsFormEnabled}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="65"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="55"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="28"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="28"/>
                    <RowDefinition Height="28"/>
                    <RowDefinition Height="28"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Symbol :" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0" FontWeight="SemiBold" FontSize="11"/>
                <ComboBox x:Name="Cmbsymbol" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="4" 
                          Style="{StaticResource EditableComboBoxStyle}"
                          ItemsSource="{Binding AvailableSymbols}"
                          Text="{Binding SelectedSymbol, UpdateSourceTrigger=PropertyChanged}"
                          SelectedItem="{Binding SelectedSymbol, UpdateSourceTrigger=PropertyChanged}"
                          IsEditable="{Binding IsSymbolEditable}"
                          IsEnabled="{Binding IsSymbolEditable}">
                </ComboBox>

                <Border Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="4" 
        BorderBrush="#2196F3" BorderThickness="1" CornerRadius="3" Height="24" Margin="0,4,0,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="BtnLimit" Grid.Column="0" Content="Limit" FontSize="11"
                Command="{Binding ChangeOrderTypeCommand}" CommandParameter="Limit">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="White"/>
                                    <Setter Property="Foreground" Value="#2196F3"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLimitActive}" Value="True">
                                            <Setter Property="Background" Value="#2196F3"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button x:Name="BtnMarket" Grid.Column="1" Content="Market" FontSize="11"
                Command="{Binding ChangeOrderTypeCommand}" CommandParameter="Market">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="White"/>
                                    <Setter Property="Foreground" Value="#2196F3"/>
                                    <Setter Property="BorderThickness" Value="1,0,1,0"/>
                                    <Setter Property="BorderBrush" Value="#2196F3"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMarketActive}" Value="True">
                                            <Setter Property="Background" Value="#2196F3"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button x:Name="BtnStopLimit" Grid.Column="2" Content="Stop Limit" FontSize="11"
                Command="{Binding ChangeOrderTypeCommand}" CommandParameter="StopLimit">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="White"/>
                                    <Setter Property="Foreground" Value="#2196F3"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsStopLimitActive}" Value="True">
                                            <Setter Property="Background" Value="#2196F3"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>

                <TextBlock Text="Quantity :" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0" FontSize="11"/>
                <TextBox x:Name="Quantitytextbox" Grid.Row="2" Grid.Column="1" 
                         Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" 
                         PreviewTextInput="NumberValidationTextBox"/>

                <TextBlock Text="Expiry :" Grid.Row="2" Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0" FontSize="11"/>
                <ComboBox x:Name="Cmbexpiry" Grid.Row="2" Grid.Column="4" Style="{StaticResource CustomComboBoxStyle}"
                          Visibility="{Binding IsExpiryVisible, Converter={StaticResource BoolToVis}}"
                          ItemsSource="{Binding ExpiryOptions}"
                          SelectedItem="{Binding SelectedExpiry, UpdateSourceTrigger=PropertyChanged}">
                </ComboBox>

                <TextBlock x:Name="lblRateLabel" Text="{Binding RateLabelText}" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0" FontSize="11"/>
                <TextBox x:Name="txtLimitRate" Grid.Row="3" Grid.Column="1" 
                         Text="{Binding LimitRate, UpdateSourceTrigger=PropertyChanged}" 
                         IsReadOnly="{Binding IsMarketActive}"
                         PreviewTextInput="NumberValidationTextBox">
                    <TextBox.Style>
                        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                            <Setter Property="Background" Value="White"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsMarketActive}" Value="True">
                                    <Setter Property="Background" Value="#F5F5F5"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <DatePicker x:Name="ExpirydatemonthPicker" Grid.Row="3" Grid.Column="4" Style="{StaticResource CustomDatePickerStyle}" Height="22" FontSize="11"
            VerticalAlignment="Center" 
            Visibility="{Binding IsSpecificDateVisible, Converter={StaticResource BoolToVis}}" SelectedDate="{Binding SelectedExpiryDate, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="Comment :" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0" FontSize="11"/>
                <TextBox x:Name="commenttextbox" Grid.Row="4" Grid.Column="1"/>
            </Grid>

            <Grid Margin="0,0,0,10" Visibility="{Binding ShowTradeActions, Converter={StaticResource BoolToVis}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="lblSellBid" Text="{Binding LiveBid}" 
           Foreground="#DC3545" FontSize="20" HorizontalAlignment="Center" FontWeight="Bold"/>

                <TextBlock x:Name="lblBuyBid" Text="{Binding LiveAsk}" 
           Grid.Column="1" Foreground="#28A745" FontSize="20" HorizontalAlignment="Center" FontWeight="Bold"/>
            </Grid>

            <Grid VerticalAlignment="Top">

                <Grid x:Name="TradeActionPanel" Visibility="{Binding ShowTradeActions, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="30"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="btnSellOrder" Grid.Column="0" 
        Command="{Binding SellCommand}" 
        Content="{Binding LeftActionText}" 
        FontSize="12" FontWeight="Bold" BorderThickness="0" Style="{StaticResource CommonActionButtonStyle}" Background="#DC3545" Foreground="White">
                            
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="3"/>
                                </Style>
                            </Button.Resources>
                        </Button>

                        <Button x:Name="btnBuyOrder" Grid.Column="2" 
        Command="{Binding BuyCommand}" 
        Content="{Binding RightActionText}" 
        Style="{StaticResource CommonActionButtonStyle}" Background="#42A5F5" Foreground="White" FontSize="12" FontWeight="Bold" BorderThickness="0">
                            
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="3"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </Grid>

                    <Button x:Name="BtnClose" Command="{Binding ClosePositionCommand}"
        Content="{Binding CloseButtonText}" 
        Visibility="{Binding IsCloseButtonVisible, Converter={StaticResource BoolToVis}}"
        Style="{StaticResource CommonActionButtonStyle}" Background="#FFC107" Foreground="Black" FontSize="12" FontWeight="SemiBold" 
        BorderThickness="0" Grid.Row="2">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="3"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>

                <Grid x:Name="OkOrderPanel" Background="White" Visibility="{Binding ShowOkPanel, Converter={StaticResource BoolToVis}}" MinHeight="80">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="lblTradeMsg" Text="{Binding TradeResultMessage}" 
               TextAlignment="Center" HorizontalAlignment="Center" VerticalAlignment="Center" 
               FontSize="12" Foreground="#333" TextWrapping="Wrap" Margin="8,8,8,10"/>

                    <Button x:Name="btnOk" Grid.Row="1" Content="OK" Width="100" Height="26" Margin="0,0,0,8" Command="{Binding OkCommand}"
            Background="#2196F3" Foreground="White" Style="{StaticResource CommonActionButtonStyle}" FontWeight="Bold" BorderThickness="0" HorizontalAlignment="Center">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="3"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </Grid>
        </StackPanel>
    </Grid>
</UserControl>