<UserControl x:Class="ClientDesktop.View.MarketWatch.MarketWatchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ClientDesktop.View.MarketWatch"
             xmlns:vm="clr-namespace:ClientDesktop.ViewModel;assembly=ClientDesktop.ViewModel"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="1100">

    <!-- Design Time DataContext -->
    <d:UserControl.DataContext>
        <vm:MarketWatchViewModel/>
    </d:UserControl.DataContext>

    <UserControl.Resources>
        <local:BindingProxy x:Key="Proxy" Data="{Binding}"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="RightAlignCell" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="0,0,5,0"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsSelected}" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BlueTextStyle" TargetType="TextBlock" BasedOn="{StaticResource RightAlignCell}">
            <Setter Property="Foreground" Value="#007ACC"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsSelected}" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RedTextStyle" TargetType="TextBlock" BasedOn="{StaticResource RightAlignCell}">
            <Setter Property="Foreground" Value="#FF3B30"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsSelected}" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <ContextMenu x:Key="RowContextMenu">
            <MenuItem Header="Specification"
                      Command="{Binding Data.ShowSpecification, Source={StaticResource Proxy}}"
                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}"> 
                <MenuItem.Icon>
                    <Path Data="M3,3H21V5H3V3M3,7H21V9H3V7M3,11H21V13H3V11M3,15H21V17H3V15Z" Fill="#666" Stretch="Uniform" Width="12"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="Chart window">
                <MenuItem.Icon>
                    <Path Data="M16,11.78L20.24,4.45L21.97,5.45L16.74,14.5L10.23,10.75L5.46,19H22V21H2V3H4V17.54L9.5,8L16,11.78Z" Fill="Green" Stretch="Uniform" Width="12"/>
                </MenuItem.Icon>
            </MenuItem>
            <Separator/>

            <MenuItem Header="Hide" 
                      Command="{Binding Data.HideSymbolCommand, Source={StaticResource Proxy}}" 
                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                <MenuItem.Icon>
                    <Path Data="M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9M12,17A5,5 0 0,1 7,12A5,5 0 0,1 12,7A5,5 0 0,1 17,12A5,5 0 0,1 12,17M12,4.5C7,4.5 2.73,7.61 1,12C2.73,16.39 7,19.5 12,19.5C17,19.5 21.27,16.39 23,12C21.27,7.61 17,4.5 12,4.5Z" Fill="#d68b00" Stretch="Uniform" Width="14"/>
                </MenuItem.Icon>
            </MenuItem>

            <MenuItem Header="Hide All" Command="{Binding Data.HideAllCommand, Source={StaticResource Proxy}}">
                <MenuItem.Icon>
                    <Path Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z" Fill="#007ACC" Stretch="Uniform" Width="12"/>
                </MenuItem.Icon>
            </MenuItem>

            <MenuItem Header="Show All" Command="{Binding Data.ShowAllCommand, Source={StaticResource Proxy}}">
                <MenuItem.Icon>
                    <Path Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4M11,7V11H7V13H11V17H13V13H17V11H13V7H11Z" Fill="#007ACC" Stretch="Uniform" Width="12"/>
                </MenuItem.Icon>
            </MenuItem>

            <MenuItem Header="Symbol">
                <MenuItem.Icon>
                    <TextBlock Text="$" FontWeight="Bold" Foreground="#e6b800" FontSize="12"/>
                </MenuItem.Icon>
            </MenuItem>
            <Separator/>

            <MenuItem Header="Column">
                <MenuItem.Icon>
                    <Path Data="M4,2H20A2,2 0 0,1 22,4V20A2,2 0 0,1 20,22H4A2,2 0 0,1 2,20V4A2,2 0 0,1 4,2M4,4V20H8V4H4M10,4V20H20V4H10Z" Fill="#555" Stretch="Uniform" Width="12"/>
                </MenuItem.Icon>

                <MenuItem Header="LTP" IsCheckable="True" IsChecked="{Binding Data.ShowLtp, Source={StaticResource Proxy}}"/>
                <MenuItem Header="High/Low" IsCheckable="True" IsChecked="{Binding Data.ShowHighLow, Source={StaticResource Proxy}}"/>
                <MenuItem Header="Open" IsCheckable="True" IsChecked="{Binding Data.ShowOpen, Source={StaticResource Proxy}}"/>
                <MenuItem Header="Close" IsCheckable="True" IsChecked="{Binding Data.ShowClose, Source={StaticResource Proxy}}"/>
                <MenuItem Header="Spread" IsCheckable="True" IsChecked="{Binding Data.ShowSpread, Source={StaticResource Proxy}}"/>
                <MenuItem Header="Daily Change %" IsCheckable="True" IsChecked="{Binding Data.ShowDcp, Source={StaticResource Proxy}}"/>
                <MenuItem Header="Daily Change Value" IsCheckable="True" IsChecked="{Binding Data.ShowDcv, Source={StaticResource Proxy}}"/>
                <MenuItem Header="Time" IsCheckable="True" IsChecked="{Binding Data.ShowTime, Source={StaticResource Proxy}}"/>
            </MenuItem>
        </ContextMenu>
    </UserControl.Resources>

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TOOLBAR -->
        <Border Grid.Row="0" Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="5,2">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Margin="0,0,10,0" VerticalAlignment="Center">
                    <Grid Width="16" Height="16" Margin="0,0,5,0">
                        <Path Data="M12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22C6.47,22 2,17.5 2,12A10,10 0 0,1 12,2M12.5,7V12.25L17,14.92L16.25,16.15L11,13V7H12.5Z" 
                              Fill="#FFA500" Stretch="Uniform"/>
                    </Grid>
                    <TextBlock Text="{Binding CurrentTime, FallbackValue='00:00:00'}" 
                               VerticalAlignment="Center" FontWeight="Bold" FontSize="14" Foreground="Black"/>
                </StackPanel>
                <Grid Margin="0,0,8,0" VerticalAlignment="Center">
                    <Border CornerRadius="2" BorderBrush="#CCCCCC" BorderThickness="1" Background="White" Height="22">
                        <Grid>
                            <TextBox x:Name="SearchBox" Width="150" 
                                     VerticalContentAlignment="Center" Padding="4,0"
                                     BorderThickness="0" Background="Transparent"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="12"/>
                            <TextBlock Text="Search Symbol" IsHitTestVisible="False" 
                                       VerticalAlignment="Center" Margin="6,0,0,0" 
                                       Foreground="#AAAAAA" FontSize="11">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>
                </Grid>
                <ComboBox Width="50" Height="22" Margin="0,0,8,0"
                          ItemsSource="{Binding FontSizes}"
                          SelectedItem="{Binding SelectedFontSize}"
                          Style="{StaticResource CustomComboBoxStyle}" 
                          ItemContainerStyle="{StaticResource CustomComboBoxItemStyle}"
                          FontSize="12" VerticalContentAlignment="Center">
                </ComboBox>
                <Button Content="Save" Width="60" Height="22" 
                        Background="#42A5F5" Foreground="White" BorderThickness="0"
                        FontWeight="SemiBold" FontSize="12"
                        Command="{Binding SaveProfileCommand}">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="2"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>

        <!-- MARKET WATCH GRID -->
        <DataGrid Grid.Row="1" 
                  x:Name="MarketGrid"
                  ItemsSource="{Binding MarketView}"
                  SelectedItem="{Binding SelectedMarketItem}"
                  FontSize="{Binding SelectedFontSize}"
                  Style="{StaticResource CustomDataGrid}"
                  AutoGenerateColumns="False" 
                  CanUserAddRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="All"
                  BorderThickness="0"
                  RowHeaderWidth="0"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  AllowDrop="True"
                  CanUserSortColumns="True"
                  PreviewMouseLeftButtonDown="DataGrid_PreviewMouseLeftButtonDown"
                  Drop="DataGrid_Drop"
                  MouseMove="DataGrid_MouseMove"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  ScrollViewer.VerticalScrollBarVisibility="Auto">

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="ContextMenu" Value="{StaticResource RowContextMenu}"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#0078D7"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <!-- Drag Handle -->
                <DataGridTemplateColumn Width="30" CanUserResize="False" CanUserSort="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Cursor="SizeAll" Background="Transparent">
                                <Path Data="M0,0 H12 M0,4 H12 M0,8 H12" StrokeThickness="1" VerticalAlignment="Top" Margin="0,2,0,0">
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Setter Property="Stroke" Value="#777"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsSelected}" Value="True">
                                                    <Setter Property="Stroke" Value="White"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                                <Path Data="M0,0 L4,4 L8,0" VerticalAlignment="Bottom" Margin="0,11,0,0">
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsUp}" Value="True">
                                                    <Setter Property="Data" Value="M0,4 L4,0 L8,4"/>
                                                    <Setter Property="Fill" Value="#007ACC"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsUp}" Value="False">
                                                    <Setter Property="Data" Value="M0,0 L4,4 L8,0"/>
                                                    <Setter Property="Fill" Value="#FF3B30"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsSelected}" Value="True">
                                                    <Setter Property="Fill" Value="White"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Symbol Width is Star -->
                <DataGridTemplateColumn Header="Symbol" Width="*" MinWidth="100" 
                                        SortMemberPath="SymbolName" CanUserSort="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding SymbolName}" VerticalAlignment="Center" Margin="5,0,0,0" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="Black"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsSelected}" Value="True">
                                                <Setter Property="Foreground" Value="White"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Bid" Width="Auto" MinWidth="70" CanUserSort="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Bid, StringFormat=N2}" Style="{StaticResource BlueTextStyle}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Ask" Width="Auto" MinWidth="70" CanUserSort="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Ask, StringFormat=N2}" Style="{StaticResource RedTextStyle}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="LTP" Width="Auto" MinWidth="70" CanUserSort="False"
                                        Visibility="{Binding Data.ShowLtp, Source={StaticResource Proxy}, Converter={StaticResource BoolToVis}}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Ltp, StringFormat=N2}" Style="{StaticResource BlueTextStyle}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="High" Binding="{Binding High, StringFormat=N2}" ElementStyle="{StaticResource RightAlignCell}" Width="Auto" MinWidth="70" CanUserSort="False"
                                    Visibility="{Binding Data.ShowHighLow, Source={StaticResource Proxy}, Converter={StaticResource BoolToVis}}"/>

                <DataGridTextColumn Header="Low" Binding="{Binding Low, StringFormat=N2}" ElementStyle="{StaticResource RightAlignCell}" Width="Auto" MinWidth="70" CanUserSort="False"
                                    Visibility="{Binding Data.ShowHighLow, Source={StaticResource Proxy}, Converter={StaticResource BoolToVis}}"/>

                <DataGridTextColumn Header="Open" Binding="{Binding Open, StringFormat=N2}" ElementStyle="{StaticResource RightAlignCell}" Width="Auto" MinWidth="70" CanUserSort="False"
                                    Visibility="{Binding Data.ShowOpen, Source={StaticResource Proxy}, Converter={StaticResource BoolToVis}}"/>

                <DataGridTextColumn Header="Close" Binding="{Binding Close, StringFormat=N2}" ElementStyle="{StaticResource RightAlignCell}" Width="Auto" MinWidth="70" CanUserSort="False"
                                    Visibility="{Binding Data.ShowClose, Source={StaticResource Proxy}, Converter={StaticResource BoolToVis}}"/>

                <!-- FIXED: Using BlueTextStyle instead of hardcoded Foreground -->
                <DataGridTemplateColumn Header="Spread" Width="Auto" MinWidth="60" CanUserSort="False"
                                        Visibility="{Binding Data.ShowSpread, Source={StaticResource Proxy}, Converter={StaticResource BoolToVis}}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Spread, StringFormat=N2}" Style="{StaticResource BlueTextStyle}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- FIXED: Using RedTextStyle instead of hardcoded Foreground -->
                <DataGridTemplateColumn Header="DCP" Width="Auto" MinWidth="60" CanUserSort="False"
                                        Visibility="{Binding Data.ShowDcp, Source={StaticResource Proxy}, Converter={StaticResource BoolToVis}}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Dcp}" Style="{StaticResource RedTextStyle}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- FIXED: Using RedTextStyle instead of hardcoded Foreground -->
                <DataGridTemplateColumn Header="DCV" Width="Auto" MinWidth="60" CanUserSort="False"
                                        Visibility="{Binding Data.ShowDcv, Source={StaticResource Proxy}, Converter={StaticResource BoolToVis}}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Dcv, StringFormat=N2}" Style="{StaticResource RedTextStyle}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- FIXED: Using BlueTextStyle instead of hardcoded Foreground -->
                <DataGridTemplateColumn Header="Time" Width="Auto" MinWidth="80" CanUserSort="False"
                                        Visibility="{Binding Data.ShowTime, Source={StaticResource Proxy}, Converter={StaticResource BoolToVis}}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Time}" Style="{StaticResource BlueTextStyle}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>