<UserControl x:Class="ClientDesktop.View.ChangePassword.ChangePasswordView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ClientDesktop.View.ChangePassword"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d" 
             Width="400"
             Background="#F5F5F5"
             Loaded="UserControl_Loaded">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="EyeButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ValidationTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="5,2,0,2"/>
        </Style>

        <Style x:Key="ValidationIconStyle" TargetType="Path">
            <Setter Property="Data" Value="M 1,6 L 4,9 L 10,2"/>
            <Setter Property="StrokeThickness" Value="1.5"/>
            <Setter Property="Width" Value="12"/>
            <Setter Property="Height" Value="12"/>
            <Setter Property="Stretch" Value="Uniform"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="15,0,5,0"/>
            <Setter Property="Stroke" Value="#E53935"/>
            <Style.Triggers>
                <Trigger Property="Tag">
                    <Trigger.Value>
                        <sys:Boolean>True</sys:Boolean>
                    </Trigger.Value>
                    <Setter Property="Stroke" Value="#4CAF50"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,30,0,20">

        <!-- Inner grid for layout of labels and inputs -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- 0: UserName -->
                <RowDefinition Height="Auto"/>
                <!-- 1: Current Password -->
                <RowDefinition Height="Auto"/>
                <!-- 2: Validation Current -->
                <RowDefinition Height="Auto"/>
                <!-- 3: New Password -->
                <RowDefinition Height="Auto"/>
                <!-- 4: Validation New -->
                <RowDefinition Height="Auto"/>
                <!-- 5: Confirm Password -->
                <RowDefinition Height="Auto"/>
                <!-- 6: Validation Confirm -->
                <RowDefinition Height="Auto"/>
                <!-- 7: Update Button -->
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>

            <!-- 0. USER NAME -->
            <TextBlock Grid.Row="0" Grid.Column="0" Text="User Name:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,15,15" FontSize="12"/>
            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding UserName}" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,0,15" FontSize="13" Foreground="Black"/>

            <!-- 1. CURRENT PASSWORD -->
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Current Password:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,15,15" FontSize="12"/>
            <Grid Grid.Row="1" Grid.Column="1" Margin="0,0,0,15">
                <PasswordBox x:Name="txtCurrent" VerticalContentAlignment="Center" Padding="4,0,25,0" BorderBrush="#ABADB3" BorderThickness="1" Height="24" FontSize="11" PasswordChanged="TxtCurrent_PasswordChanged"/>
                <TextBox x:Name="txtCurrentVis" Visibility="Collapsed" VerticalContentAlignment="Center" Padding="4,0,25,0" BorderBrush="#ABADB3" BorderThickness="1" Height="24" FontSize="11"/>

                <Button x:Name="btnEyeCurrent" Style="{StaticResource EyeButtonStyle}" Click="BtnEyeCurrent_Click" Width="20" Height="20" HorizontalAlignment="Right" Margin="0,0,4,0">
                    <Grid>
                        <Path x:Name="pathEyeClosedCurrent" Data="M11.83,9L15,12.16C15,12.11 15,12.05 15,12A3,3 0 0,0 12,9C11.94,9 11.89,9 11.83,9M7.53,9.8L9.08,11.35C9.03,11.56 9,11.77 9,12A3,3 0 0,0 12,15C12.22,15 12.44,14.97 12.65,14.92L14.2,16.47C13.53,16.8 12.79,17 12,17A5,5 0 0,1 7,12C7,11.21 7.2,10.47 7.53,9.8M2,4.27L4.28,6.55L4.73,7C3.08,8.3 1.78,10.02 1,12C2.73,16.39 7,19.5 12,19.5C13.55,19.5 15.03,19.2 16.38,18.66L16.81,19.08L19.73,22L21,20.73L3.27,3M12,7A5,5 0 0,1 17,12C17,12.64 16.87,13.26 16.64,13.82L19.57,16.75C21.07,15.5 22.27,13.86 23,12C21.27,7.61 17,4.5 12,4.5C10.6,4.5 9.26,4.75 8,5.2L10.17,7.35C10.74,7.13 11.35,7 12,7Z" Fill="#666" Stretch="Uniform" Width="14" Height="14"/>
                        <Path x:Name="pathEyeOpenCurrent" Visibility="Collapsed" Data="M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9M12,4.5C17,4.5 21.27,7.61 23,12C21.27,16.39 17,19.5 12,19.5C7,19.5 2.73,16.39 1,12C2.73,7.61 7,4.5 12,4.5M3.18,12C4.83,15.36 8.24,17.5 12,17.5C15.76,17.5 19.17,15.36 20.82,12C19.17,8.64 15.76,6.5 12,6.5C8.24,6.5 4.83,8.64 3.18,12Z" Fill="#2196F3" Stretch="Uniform" Width="14" Height="14"/>
                    </Grid>
                </Button>
            </Grid>

            <!-- 2. CURRENT PASSWORD VALIDATION -->
            <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,15" Visibility="{Binding IsCurrentValidationVisible, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal">
                    <Path Style="{StaticResource ValidationIconStyle}" Tag="{Binding IsCurrentPasswordValid}"/>
                    <TextBlock Text="Matches current password" Style="{StaticResource ValidationTextStyle}"/>
                </StackPanel>
            </StackPanel>

            <!-- 3. NEW PASSWORD -->
            <TextBlock Grid.Row="3" Grid.Column="0" Text="New Password:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,15,10" FontSize="12"/>
            <Grid Grid.Row="3" Grid.Column="1" Margin="0,0,0,10" IsEnabled="{Binding IsNewPasswordEnabled}">
                <PasswordBox x:Name="txtNew" VerticalContentAlignment="Center" Padding="4,0,25,0" BorderBrush="#ABADB3" BorderThickness="1" Height="24" FontSize="11" PasswordChanged="TxtNew_PasswordChanged"/>
                <TextBox x:Name="txtNewVis" Visibility="Collapsed" VerticalContentAlignment="Center" Padding="4,0,25,0" BorderBrush="#ABADB3" BorderThickness="1" Height="24" FontSize="11"/>

                <Button x:Name="btnEyeNew" Style="{StaticResource EyeButtonStyle}" Click="BtnEyeNew_Click" Width="20" Height="20" HorizontalAlignment="Right" Margin="0,0,4,0">
                    <Grid>
                        <Path x:Name="pathEyeClosedNew" Data="M11.83,9L15,12.16C15,12.11 15,12.05 15,12A3,3 0 0,0 12,9C11.94,9 11.89,9 11.83,9M7.53,9.8L9.08,11.35C9.03,11.56 9,11.77 9,12A3,3 0 0,0 12,15C12.22,15 12.44,14.97 12.65,14.92L14.2,16.47C13.53,16.8 12.79,17 12,17A5,5 0 0,1 7,12C7,11.21 7.2,10.47 7.53,9.8M2,4.27L4.28,6.55L4.73,7C3.08,8.3 1.78,10.02 1,12C2.73,16.39 7,19.5 12,19.5C13.55,19.5 15.03,19.2 16.38,18.66L16.81,19.08L19.73,22L21,20.73L3.27,3M12,7A5,5 0 0,1 17,12C17,12.64 16.87,13.26 16.64,13.82L19.57,16.75C21.07,15.5 22.27,13.86 23,12C21.27,7.61 17,4.5 12,4.5C10.6,4.5 9.26,4.75 8,5.2L10.17,7.35C10.74,7.13 11.35,7 12,7Z" Fill="#666" Stretch="Uniform" Width="14" Height="14"/>
                        <Path x:Name="pathEyeOpenNew" Visibility="Collapsed" Data="M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9M12,4.5C17,4.5 21.27,7.61 23,12C21.27,16.39 17,19.5 12,19.5C7,19.5 2.73,16.39 1,12C2.73,7.61 7,4.5 12,4.5M3.18,12C4.83,15.36 8.24,17.5 12,17.5C15.76,17.5 19.17,15.36 20.82,12C19.17,8.64 15.76,6.5 12,6.5C8.24,6.5 4.83,8.64 3.18,12Z" Fill="#2196F3" Stretch="Uniform" Width="14" Height="14"/>
                    </Grid>
                </Button>
            </Grid>

            <!-- 4. VALIDATION RULES -->
            <StackPanel Grid.Row="4" Grid.Column="1" Margin="0,0,0,15" Visibility="{Binding IsValidationVisible, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal">
                    <Path Style="{StaticResource ValidationIconStyle}" Tag="{Binding HasDigit}"/>
                    <TextBlock Text="Atleast 1 digit required" Style="{StaticResource ValidationTextStyle}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Path Style="{StaticResource ValidationIconStyle}" Tag="{Binding HasAlphabet}"/>
                    <TextBlock Text="Atleast 1 alphabet required" Style="{StaticResource ValidationTextStyle}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Path Style="{StaticResource ValidationIconStyle}" Tag="{Binding HasMinLength}"/>
                    <TextBlock Text="Minimum 6 digit required" Style="{StaticResource ValidationTextStyle}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                    <Path Style="{StaticResource ValidationIconStyle}" Tag="{Binding IsNotOldPassword}" VerticalAlignment="Bottom" Margin="15,0,5,3"/>
                    <TextBlock Style="{StaticResource ValidationTextStyle}">
                        <Run Text="New Password can't be same as"/><LineBreak/>
                        <Run Text="Old Password"/>
                    </TextBlock>
                </StackPanel>
            </StackPanel>

            <!-- 5. CONFIRM PASSWORD -->
            <TextBlock Grid.Row="5" Grid.Column="0" Text="Confirm Password:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,15,10" FontSize="12"/>
            <Grid Grid.Row="5" Grid.Column="1" Margin="0,0,0,10" IsEnabled="{Binding IsConfirmPasswordEnabled}">
                <PasswordBox x:Name="txtConfirm" VerticalContentAlignment="Center" Padding="4,0,25,0" BorderBrush="#ABADB3" BorderThickness="1" Height="24" FontSize="11" PasswordChanged="TxtConfirm_PasswordChanged"/>
                <TextBox x:Name="txtConfirmVis" Visibility="Collapsed" VerticalContentAlignment="Center" Padding="4,0,25,0" BorderBrush="#ABADB3" BorderThickness="1" Height="24" FontSize="11"/>

                <Button x:Name="btnEyeConfirm" Style="{StaticResource EyeButtonStyle}" Click="BtnEyeConfirm_Click" Width="20" Height="20" HorizontalAlignment="Right" Margin="0,0,4,0">
                    <Grid>
                        <Path x:Name="pathEyeClosedConfirm" Data="M11.83,9L15,12.16C15,12.11 15,12.05 15,12A3,3 0 0,0 12,9C11.94,9 11.89,9 11.83,9M7.53,9.8L9.08,11.35C9.03,11.56 9,11.77 9,12A3,3 0 0,0 12,15C12.22,15 12.44,14.97 12.65,14.92L14.2,16.47C13.53,16.8 12.79,17 12,17A5,5 0 0,1 7,12C7,11.21 7.2,10.47 7.53,9.8M2,4.27L4.28,6.55L4.73,7C3.08,8.3 1.78,10.02 1,12C2.73,16.39 7,19.5 12,19.5C13.55,19.5 15.03,19.2 16.38,18.66L16.81,19.08L19.73,22L21,20.73L3.27,3M12,7A5,5 0 0,1 17,12C17,12.64 16.87,13.26 16.64,13.82L19.57,16.75C21.07,15.5 22.27,13.86 23,12C21.27,7.61 17,4.5 12,4.5C10.6,4.5 9.26,4.75 8,5.2L10.17,7.35C10.74,7.13 11.35,7 12,7Z" Fill="#666" Stretch="Uniform" Width="14" Height="14"/>
                        <Path x:Name="pathEyeOpenConfirm" Visibility="Collapsed" Data="M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9M12,4.5C17,4.5 21.27,7.61 23,12C21.27,16.39 17,19.5 12,19.5C7,19.5 2.73,16.39 1,12C2.73,7.61 7,4.5 12,4.5M3.18,12C4.83,15.36 8.24,17.5 12,17.5C15.76,17.5 19.17,15.36 20.82,12C19.17,8.64 15.76,6.5 12,6.5C8.24,6.5 4.83,8.64 3.18,12Z" Fill="#2196F3" Stretch="Uniform" Width="14" Height="14"/>
                    </Grid>
                </Button>
            </Grid>

            <!-- 6. CONFIRM VALIDATION -->
            <StackPanel Grid.Row="6" Grid.Column="1" Margin="0,0,0,15" Visibility="{Binding IsConfirmValidationVisible, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                    <Path Style="{StaticResource ValidationIconStyle}" Tag="{Binding PasswordsMatch}" VerticalAlignment="Bottom" Margin="15,0,5,3"/>
                    <TextBlock Style="{StaticResource ValidationTextStyle}">
                        <Run Text="Confirm Password must match"/><LineBreak/>
                        <Run Text="New Password"/>
                    </TextBlock>
                </StackPanel>
            </StackPanel>

            <!-- 7. UPDATE BUTTON -->
            <StackPanel Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2" HorizontalAlignment="Center" Margin="15,5,0,0">
                <Button Content="Update" 
                        Width="90" Height="30" 
                        Background="#42A5F5" Foreground="White"
                        Style="{StaticResource CommonActionButtonStyle}"
                        IsEnabled="{Binding IsUpdateEnabled}"
                        IsDefault="True"
                        Command="{Binding UpdateCommand}"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>