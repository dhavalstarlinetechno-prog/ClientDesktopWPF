                            </Canvas>
                        </Viewbox>
                        <Label x:Name="LblThursday" Content="Thursday" Grid.Column="1" Grid.Row="4" VerticalContentAlignment="Center" FontFamily="Microsoft Sans Serif" FontSize="12"/>
                        <Label x:Name="Lblthursdayquotedate" Content="" Grid.Column="2" Grid.Row="4" HorizontalContentAlignment="Left" VerticalContentAlignment="Center" FontFamily="Microsoft Sans Serif" FontSize="12"/>
                        <Label x:Name="Lblthursdaytradedate" Content="" Grid.Column="3" Grid.Row="4" HorizontalContentAlignment="Left" VerticalContentAlignment="Center" FontFamily="Microsoft Sans Serif" FontSize="12"/>

