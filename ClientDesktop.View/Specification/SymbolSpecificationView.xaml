                        <Label x:Name="Lblfridaytradedate" Content="" Grid.Column="3" Grid.Row="5" HorizontalContentAlignment="Left" VerticalContentAlignment="Center" FontFamily="Microsoft Sans Serif" FontSize="12"/>

