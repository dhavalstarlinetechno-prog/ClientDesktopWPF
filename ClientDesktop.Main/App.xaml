             xmlns:local="clr-namespace:ClientDesktop.Main">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/ClientDesktop.UserControl;component/Themes/CustomGridStyle.xaml"/>
