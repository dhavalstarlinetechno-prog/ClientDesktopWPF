<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:bal="http://wixtoolset.org/schemas/v4/wxs/bal"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util"
     xmlns:netfx="http://wixtoolset.org/schemas/v4/wxs/netfx">
	<?define IsOfflineInstaller = "false" ?>

	<Bundle Name="Client Desktop" Manufacturer="ClientDesktop"
		Version="1.0.0.0" UpgradeCode="0A80ECA5-48D6-44E2-A371-423F8228FCFF"
		IconSourceFile="..\ClientDesktop.Main\Assets\app_icon.ico">

		<BootstrapperApplication>
			<bal:WixInternalUIBootstrapperApplication />
		</BootstrapperApplication>

		<netfx:DotNetCoreSearch Id="DotNetVerFind"
		                        Variable="DOT_NET_VER"
		                        RuntimeType="desktop"
		                        Platform="x86"
		                        MajorVersion="8" />

		<Chain>
			<?if $(var.IsOfflineInstaller) = "true" ?>
			<ExePackage Id="Net8Offline"
						DisplayName="Microsoft .NET 8.0 Desktop Runtime (x86)"
						SourceFile="dotnet8-x86.exe"
						InstallArguments="/install /quiet /norestart"
						DetectCondition="DOT_NET_VER AND DOT_NET_VER &gt;= v8.0.0"
						Permanent="yes" />
			<?endif ?>

			<?if $(var.IsOfflineInstaller) = "false" ?>
			<ExePackage Id="Net8Online"
						DisplayName="Microsoft .NET 8.0 Desktop Runtime (x86)"
						SourceFile="dotnet8-x86.exe"
						DownloadUrl="https://aka.ms/dotnet/8.0/windowsdesktop-runtime-win-x86.exe"
						InstallArguments="/install /quiet /norestart"
						DetectCondition="DOT_NET_VER AND DOT_NET_VER &gt;= v8.0.0"
						Compressed="no"
						Permanent="yes" />
			<?endif ?>

			<MsiPackage SourceFile="$(var.ClientDesktop.Installer.TargetPath)" />
		</Chain>
	</Bundle>
</Wix>